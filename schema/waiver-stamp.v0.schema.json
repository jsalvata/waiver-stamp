{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://waiver-stamp.dev/schema/waiver-stamp.v0.schema.json",
  "title": "waiver-stamp/v0",
  "type": "object",
  "properties": {
    "schema": {
      "description": "Vocabulary/validation version.",
      "type": "string",
      "const": "waiver-stamp/v0"
    },
    "tool": {
      "description": "Pins op semantics + bundled ts-morph; stamp refuses on mismatch.",
      "type": "string",
      "pattern": "^waiver-stamp@.+$"
    },
    "ops": {
      "description": "Ordered list; transform ops apply in order, exclusion ops are order-free.",
      "type": "array",
      "items": {
        "anyOf": [
          {
            "description": "Rename a symbol and all references within the loaded program.",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "rename"
              },
              "target": {
                "description": "A single declaration, addressed by file + TSDoc declaration reference.",
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "symbol": {
                    "description": "A TSDoc declaration reference, never line:col.",
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "file",
                  "symbol"
                ],
                "additionalProperties": false
              },
              "to": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "op",
              "target",
              "to"
            ],
            "additionalProperties": false
          },
          {
            "description": "Extract a node/span into a named function.",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "extract-function"
              },
              "target": {
                "description": "A node or a contiguous sibling span within one body.",
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "minLength": 1
                  },
                  "within": {
                    "description": "The enclosing function/method (a TSDoc symbol).",
                    "type": "string",
                    "minLength": 1
                  },
                  "from": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "description": "A verbatim source snippet; normalized at resolution.",
                        "type": "string",
                        "minLength": 1
                      },
                      "nth": {
                        "description": "Disambiguates in document order.",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": [
                      "text"
                    ],
                    "additionalProperties": false
                  },
                  "to": {
                    "description": "Omit for a single node; present for a from..to span.",
                    "type": "object",
                    "properties": {
                      "text": {
                        "description": "A verbatim source snippet; normalized at resolution.",
                        "type": "string",
                        "minLength": 1
                      },
                      "nth": {
                        "description": "Disambiguates in document order.",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": [
                      "text"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "file",
                  "within",
                  "from"
                ],
                "additionalProperties": false
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "op",
              "target",
              "name"
            ],
            "additionalProperties": false
          },
          {
            "description": "Move named top-level declarations to a new file, rewiring imports/exports.",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "move-to-new-file"
              },
              "symbols": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "op",
              "symbols",
              "from",
              "to"
            ],
            "additionalProperties": false
          },
          {
            "description": "Bump allowlisted dependency versions (manifest + lockfile only).",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "bump"
              },
              "packages": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "op",
              "packages"
            ],
            "additionalProperties": false
          },
          {
            "description": "Arbitrary edits to verified non-shipping test files.",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "change-test"
              },
              "files": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "op",
              "files"
            ],
            "additionalProperties": false
          },
          {
            "description": "Arbitrary edits to verified non-shipping doc files.",
            "type": "object",
            "properties": {
              "op": {
                "type": "string",
                "const": "change-docs"
              },
              "files": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "required": [
              "op",
              "files"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "schema",
    "tool",
    "ops"
  ],
  "additionalProperties": false
}
