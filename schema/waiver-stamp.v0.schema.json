{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://waiver-stamp.dev/schema/waiver-stamp.v0.schema.json",
  "title": "waiver-stamp/v0",
  "description": "A waiver: an ordered list of operations that, when stamped against a PR diff, prove the change is safe to auto-approve. Single source of truth for the v0 op vocabulary (see docs/spec.md §5).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "tool", "ops"],
  "properties": {
    "schema": {
      "description": "Vocabulary/validation version.",
      "const": "waiver-stamp/v0"
    },
    "tool": {
      "description": "Pins op semantics + bundled ts-morph; stamp refuses on mismatch.",
      "type": "string",
      "pattern": "^waiver-stamp@.+$"
    },
    "ops": {
      "description": "Ordered list; transform ops apply in order, exclusion ops are order-free.",
      "type": "array",
      "items": { "$ref": "#/definitions/op" }
    }
  },
  "definitions": {
    "op": {
      "oneOf": [
        { "$ref": "#/definitions/rename" },
        { "$ref": "#/definitions/extractFunction" },
        { "$ref": "#/definitions/moveToNewFile" },
        { "$ref": "#/definitions/bump" },
        { "$ref": "#/definitions/changeTest" },
        { "$ref": "#/definitions/changeDocs" }
      ]
    },
    "selector": {
      "description": "A single declaration: file + a TSDoc declaration reference (§5.2).",
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "symbol"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "minLength": 1 }
      }
    },
    "nodeAnchor": {
      "description": "A verbatim source snippet (normalized at resolution) addressing one node; nth disambiguates in document order.",
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "nth": { "type": "integer", "minimum": 1 }
      }
    },
    "nodeLocator": {
      "description": "A node or a contiguous sibling span within one body (§5.2).",
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "within", "from"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "within": { "type": "string", "minLength": 1 },
        "from": { "$ref": "#/definitions/nodeAnchor" },
        "to": { "$ref": "#/definitions/nodeAnchor" }
      }
    },
    "rename": {
      "description": "Transform · reproductive. Rename a symbol and all references within the loaded program.",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "to"],
      "properties": {
        "op": { "const": "rename" },
        "target": { "$ref": "#/definitions/selector" },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "extractFunction": {
      "description": "Transform · reproductive. Extract a node/span into a named function.",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "target", "name"],
      "properties": {
        "op": { "const": "extract-function" },
        "target": { "$ref": "#/definitions/nodeLocator" },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "moveToNewFile": {
      "description": "Transform · reproductive. Move named top-level declarations to a new file, rewiring imports/exports.",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "symbols", "from", "to"],
      "properties": {
        "op": { "const": "move-to-new-file" },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "bump": {
      "description": "Transform · transitive. Bump allowlisted dependency versions (manifest + lockfile only).",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "packages"],
      "properties": {
        "op": { "const": "bump" },
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "changeTest": {
      "description": "Exclusion · confinement. Arbitrary edits to verified non-shipping test files.",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "files"],
      "properties": {
        "op": { "const": "change-test" },
        "files": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "changeDocs": {
      "description": "Exclusion · confinement. Arbitrary edits to verified non-shipping doc files.",
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "files"],
      "properties": {
        "op": { "const": "change-docs" },
        "files": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
