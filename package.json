{
  "name": "waiver-stamp",
  "version": "0.0.0",
  "description": "Auto-approve PRs whose safety can be proven mechanically. A waiver is a JSON recipe describing a change; stamping validates a PR's diff against its waiver.",
  "keywords": ["refactor", "ts-morph", "pull-request", "code-review", "typescript"],
  "license": "MIT",
  "author": "Jordi Salvat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsalvata/waiver-stamp.git"
  },
  "bugs": {
    "url": "https://github.com/jsalvata/waiver-stamp/issues"
  },
  "homepage": "https://github.com/jsalvata/waiver-stamp#readme",
  "type": "module",
  "bin": {
    "waiver": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "schema", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "gen:schema": "tsx scripts/gen-schema.ts",
    "build": "pnpm gen:schema && tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky",
    "bench": "tsx scripts/bench.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "ts-morph": "^24.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.7.0",
    "husky": "^9.1.6",
    "semantic-release": "^24.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
